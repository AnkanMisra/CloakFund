# CloakFund Environment Variables Example
# Do not add real secrets to this file!

# --- Server Configuration ---
PORT=8080
FRONTEND_URL=http://localhost:3000

# --- Convex ---
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SITE_URL=https://your-deployment.convex.site

# --- Blockchain RPCs ---
# Base network RPC (HTTP and WSS) for deposit watching
BASE_RPC_URL=https://sepolia.base.org
BASE_WSS_URL=wss://base-sepolia-rpc.publicnode.com
BASE_CHAIN_ID=84532
BASE_NETWORK=base-sepolia

# Ethereum Mainnet RPC (for ENS resolution)
ETH_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# --- Stealth Address ---
RECIPIENT_PRIVATE_KEY_HEX=your_recipient_private_key_hex

# --- ZK-Mixer (PrivacyPool) ---
# Deployed PrivacyPool.sol contract address
PRIVACY_POOL_ADDRESS=0xYOUR_DEPLOYED_PRIVACY_POOL_ADDRESS
# Relayer hot-wallet private key (pays gas for anonymous withdrawals)
RELAYER_PRIVATE_KEY=0xYOUR_RELAYER_PRIVATE_KEY

# --- Sender (for testing) ---
SENDER_PRIVATE_KEY=0xYOUR_SENDER_PRIVATE_KEY

# --- Dev Flags ---
#SWEEPER_DRY_RUN=false
#REQUIRED_CONFIRMATIONS=2
