# CloakFund Environment Variables Example
# Do not add real secrets to this file!

# --- Server Configuration ---
PORT=8080
FRONTEND_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgres://user:password@localhost:5432/cloakfund

# --- Blockchain RPCs ---
# Base network RPC (HTTP and WSS) for deposit watching
BASE_RPC_URL=https://mainnet.base.org
BASE_WSS_URL=wss://mainnet.base.org/ws

# Ethereum Mainnet RPC (for ENS resolution)
ETH_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# --- External APIs ---
# BitGo MPC Treasury
BITGO_API_KEY=your_bitgo_api_key_here
BITGO_ENV=test # test or prod

# Fileverse (Encrypted Receipts)
FILEVERSE_API_KEY=your_fileverse_api_key_here

# --- Mocking / Dev Flags ---
USE_MOCK_BITGO=true
USE_MOCK_FILEVERSE=true
